{
  "name": "coacom-system",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema Web de Gestión de Servicios y Personal Técnico — COACOM SRL",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
